{
    "manifest_version": 3,
    "name": "Auth Vault",
    "version": "1.0.0",
    "description": "Secure OTP Authenticator Manager",
    "action": {
        "default_popup": "index.html",
        "default_icon": "favicon.svg"
    },
    "icons": {
        "16": "favicon.svg",
        "48": "favicon.svg",
        "128": "favicon.svg"
    },
    "permissions": [
        "storage",
        "clipboardWrite"
    ]
}